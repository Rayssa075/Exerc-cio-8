#include <iostream>
#include <string>
#include <vector>

int main() {
    vector<std::string> lista;
    string entrada;
    int maiorComprimento = 0;

 cout << "Digite até 20 palavras (digite 'fim' para parar):" <<endl;

    // Leitura das strings
    for (int i = 0; i < 20; i++) {
        cout << (i + 1) << ": ";
        getline(cin, entrada);
        
        if (entrada == "fim") break;
        
        lista.push_back(entrada);
        if (lista[i].length() > maiorComprimento) {
            maiorComprimento = lista[i].length();
        }
    }

    int limiteInferior = maiorComprimento / 2;
    vector<std::string> filtradas;

    for (const std::string &s : lista) {
        if (s.length() >= limiteInferior && s.length() <= maiorComprimento) {
            filtradas.push_back(s);
        }
    }

    // Exibição dos resultados
    cout << "\n--- Palavras filtradas (comprimento entre " << limiteInferior 
              << " e " << maiorComprimento << ") ---" <<endl;
    for (const string &s : filtradas) {
       cout << s <<endl;
    }

    return 0;
}
