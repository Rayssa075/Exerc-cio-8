#include <iostream>
#include <string>
#include <algorithm> 

bool ehPalindromo(const string &palavra) {
    int inicio = 0;
    int fim = palavra.length() - 1;

    while (inicio < fim) {
        if (palavra[inicio] != palavra[fim]) {
            return false;
        }
        inicio++;
        fim--;
    }
    return true;
}

int main() {
    std::string palavra;

    cout << "Digite uma palavra para verificar se eh palindromo: ";
    cin >> palavra;

    if (ehPalindromo(palavra)) {
        std::cout << "A palavra " << palavra << " eh um palindromo!" <<endl;
    } else {
        std::cout << "A palavra " << palavra << " nao eh um palindromo." <<endl;
    }

    return 0;
}
