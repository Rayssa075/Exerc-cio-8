#include <iostream>
#include <string>

int contarESubstituir(std::string &s) {
    int contador = 0;
    for (int i = 0; i < s.length(); i++) {
        if (s[i] == 'a') {
            s[i] = 'b';
            contador++;
        }
    }
    return contador;
}

int main() {
    std::string texto;
    
    std::cout << "Digite uma string: ";
    std::getline(std::cin, texto);

    int modificacoes = contarESubstituir(texto);

    std::cout << "Caracteres modificados: " << modificacoes <<endl;
    std::cout << "String modificada: " << texto <<endl;

    return 0;
}
