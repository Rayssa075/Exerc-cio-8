#include <iostream>
#include <string>

bool saoMesmasCidades(const std::string &nasceu, const std::string &reside) {
    return (nasceu == reside);
}
void processarVogais(std::string &cidade) {
    int contador = 0;
    std::string vogais = "aeiouAEIOU";

    for (int i = 0; i < cidade.length(); i++) {
        if (vogais.find(cidade[i]) != std::string::npos) {
            contador++;
            cidade[i] = '?';
        }
    }

   cout << "Quantidade de vogais substituídas: " << contador << std::endl;
   cout << "Cidade alterada: " << cidade << std::endl;
}

int main() {
    std::string nasceu, reside;

   cout << "Cidade onde nasceu: ";
  getline(std::cin, nasceu);
 cout << "Cidade onde reside: ";
    getline(std::cin, reside);

    if (saoMesmasCidades(nasceu, reside)) {
